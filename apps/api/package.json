    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.3",
    "pg": "^8.15.6",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/pg": "^8.11.14",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
