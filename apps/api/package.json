{
	"name": "@dental/api",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"start": "node dist/server.js",
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"test": "tsx --test src/tests/*.test.ts"
	},
	"dependencies": {
		"@dental/shared": "*",
		"@electric-sql/pglite": "^0.5.4",
		"@electric-sql/pglite-sync": "^0.6.5",
		"@fastify/cors": "^10.0.1",
		"@fastify/multipart": "^10.1.0",
		"@fastify/rate-limit": "^11.1.0",
		"@fastify/websocket": "^11.3.0",
		"chokidar": "^5.0.0",
		"decimal.js": "^10.6.0",
		"dicom-parser": "^1.8.21",
		"dotenv": "^16.5.0",
		"drizzle-orm": "^0.45.2",
		"fastify": "^5.3.3",
		"fuse.js": "^7.4.2",
		"jsonwebtoken": "^9.0.3",
		"pg": "^8.15.6",
		"qrcode": "^1.5.4",
		"sharp": "^0.35.3",
		"socks-proxy-agent": "^10.1.0",
		"undici": "^8.5.0",
		"zod": "^3.24.4"
	},
	"devDependencies": {
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^22.15.18",
		"@types/pg": "^8.11.14",
		"@types/qrcode": "^1.5.6",
		"drizzle-kit": "^0.31.10",
		"tsx": "^4.19.4",
		"typescript": "^5.8.3"
	}
}
