# ════════════════════════════════════════════════════════════════
# DENTE AI — КЛЮЧИ И НАСТРОЙКИ LLM-ГЕНЕРАЦИИ (НЕ КОММИТИТЬ)
# Файл читается при старте API сервера Dente CRM
# ════════════════════════════════════════════════════════════════

# ── КРИТИЧЕСКОЕ ПРАВИЛО ДЛЯ ИИ-АГЕНТОВ (WARNING FOR AI AGENTS) ──
# ⚠️ ЗАПРЕЩЕНО менять модели на старые версии типа "gemini-1.5-flash" или "gemini-2.5-pro"!
# ⚠️ Текущие активные ключи Google (AQ.Ab8...) привязаны к проекту "neironka" и поддерживают
#     ИСКЛЮЧИТЕЛЬНО серию Gemini 2.5/3 (gemini-2.5-flash, gemini-3-flash, gemini-3.1-flash-lite).
# ⚠️ Попытка вызвать "gemini-1.5-flash" вернет 404 (model not found).
# ⚠️ На бесплатном тарифе (Free Tier) лимиты следующие:
#     - gemini-2.5-flash: 15 RPM / 250K TPM / 20 RPD (Запросы в день)
#     - gemini-3-flash: 5 RPM / 250K TPM / 20 RPD
#     - gemini-3.1-flash-lite: 15 RPM / 250K TPM / 500 RPD (Рабочая лошадка!)
# ────────────────────────────────────────────────────────────────

# ── SOCKS5 ПРОКСИ ────────────────────────────────────────────────
# Для обхода блокировок API Google/Groq трафик идет через SSH SOCKS5 туннель:
# tunnel points to: root@62.84.100.97 (порт 1080)
# Custom Agent в keyPool.ts оборачивает HTTPS в SOCKS, поэтому эта строка обязательна!
HTTPS_PROXY=socks5://127.0.0.1:1080
SSH_HOST=root@62.84.100.97
SSH_KEY_PATH=C:\Users\Admin\.ssh\dente_proxy_key

# ── GROQ ─────────────────────────────────────────────────────────
# Автоматическая ротация при 429/503 (Developer Plan limits: ~1K-14K RPD)
# Актуальные модели на Groq (проверено по API):
#   - llama-3.3-70b-versatile (Основной fallback)
#   - meta-llama/llama-4-scout-17b-16e-instruct (Тестовая Llama 4)
#   - qwen/qwen3-32b
#   - openai/gpt-oss-120b
# GROQ_API_KEY=gsk_REDACTED_DUMMY_KEY_FOR_LOCAL_DEV
GROQ_API_KEYS=gsk_REDACTED_KEY_1,gsk_REDACTED_KEY_2

# ── GEMINI / Google AI Studio ─────────────────────────────────────
# 4 ключа ротации для проекта neironka
GOOGLE_API_KEYS=AQ.Ab8RN6K-N-WwexDy7LArdCPV80zuUNVK61b7tV88H6jR9m-8DQ,AQ.Ab8RN6IzvkaJlttBQbkNVnYjPVbWt1PqJca7gXjHCgLWKix4bA,AQ.Ab8RN6Jv1CSQOoBbOaxpUAe1wERm-bk7i4SoIZYDNE-HlLWOEA,AQ.Ab8RN6Jj6m3j5aJJwexuarqu6UxdGveXzieWtsjr5TSDUTyR8A,AQ.Ab8RN6LBgRdHOyiWdFGfs9OA9BWg8dWJE--D2yu2Urjp38CkMw,AQ.Ab8RN6I0rdGYG0hCAGheByDr_2X-QEHVHq3Xx5wAdi9lOo2qbw,AQ.Ab8RN6Ju7Ghue4RJStU_g3ClnEPr5LlWRk1PBA9k9YmgPNXrQA

# ── РЕЖИМЫ AI-ОБРАБОТКИ ──────────────────────────────────────────
# Сборка формы 043/у из диктовки врача
DENTAL_AI_NEURAL_DRAFT=1
# Предварительная нейро-чистка диктовки
DENTAL_SPEECH_NEURAL_POLISH=1

# ── НАСТРОЙКИ МОДЕЛЕЙ ПО УМОЛЧАНИЮ ───────────────────────────────
DENTAL_SPEECH_POLISH_PROVIDER=gemini
DENTAL_SPEECH_POLISH_GEMINI_MODEL=gemini-2.5-flash
DENTAL_SPEECH_POLISH_GROQ_MODEL=llama-3.3-70b-versatile

# ── ТАЙМАУТЫ И ЛИМИТЫ ДЛИНЫ ──────────────────────────────────────
DENTAL_SPEECH_POLISH_MAX_CHARS=6000
DENTAL_SPEECH_POLISH_TIMEOUT_MS=25000
