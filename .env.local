NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4100
WEB_ORIGIN=http://127.0.0.1:5173
DENTAL_STATE_FILE=C:\hades\dental-crm\.data\dental-crm-state.json
DENTAL_STATE_BACKUP_DIR=C:\hades\dental-crm\.data\backups
DENTAL_STATE_BACKUPS=30

# Local bridge only: real secrets stay in the old project env and are loaded
# server-side by apps/api/src/env/loadServerEnv.ts.
DENTAL_EXTRA_ENV_FILES=C:\Users\Admin\Desktop\dvachbot\.env,C:\Clinic_MVP\dental-crm\local-secrets\ai.env

# The detected external env currently has a GROQ_API_KEYS pool, so Groq is the
# first STT provider for voice. The API rotates keys randomly and applies
# cooldowns after rate-limit/auth/timeout/provider failures.
DENTAL_SPEECH_PROVIDER=groq
DENTAL_SPEECH_KEY_RETRY_LIMIT=3
DENTAL_SPEECH_PROVIDER_TIMEOUT_MS=45000
DENTAL_SPEECH_RATE_LIMIT_COOLDOWN_MS=60000
DENTAL_SPEECH_ERROR_COOLDOWN_MS=30000
DENTAL_SPEECH_AUTH_COOLDOWN_MS=600000
DENTE_CLINICAL_ALLOW_UNGUARDED_MUTATIONS=1
DENTE_CLINICAL_ALLOW_UNGUARDED_READS=1
DENTE_SETTINGS_ALLOW_UNGUARDED_MUTATIONS=1

# ИИ-полировка диктовки и автогенерация ЭМК
DENTAL_SPEECH_NEURAL_POLISH=true
DENTAL_AI_NEURAL_DRAFT=true
DENTAL_SPEECH_POLISH_PROVIDER=gemini
DENTAL_SPEECH_POLISH_MODEL=gemini-2.5-flash
